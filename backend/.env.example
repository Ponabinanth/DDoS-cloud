PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/securechain
JWT_SECRET=your_super_secret_jwt_key_change_in_production
NODE_ENV=development

# Frontend allowlist (prevents open-redirect in OAuth flows)
FRONTEND_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
FRONTEND_DEFAULT_RETURN_TO=http://127.0.0.1:5500/login.html

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Apple Sign-In (optional, requires Apple Developer)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Use \n for newlines in the PEM value.
APPLE_PRIVATE_KEY=
